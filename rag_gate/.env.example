# Django Configuration
SECRET_KEY=django-insecure-change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=*

# Database
DATABASE_URL=postgres://raggate:raggate_secret@localhost:5432/raggate

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM Provider API Keys
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI-Compatible Providers (Groq, OpenRouter, Together, etc.)
# Default base URL (e.g., https://api.groq.com/openai/v1)
DEFAULT_OPENAI_COMPATIBLE_BASE_URL=
# Default API key for the compatible provider
DEFAULT_OPENAI_COMPATIBLE_API_KEY=

# Daily Quota
QUOTA_DAILY_LIMIT=30